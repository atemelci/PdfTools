{
  "name": "pdf-tools",
  "productName": "PDF Tools",
  "version": "1.0.0",
  "description": "Offline PDF toolkit — merge, split, rotate, edit, extract and convert PDFs. Runs as a standalone Windows app with no installation or internet required.",
  "author": "PdfTools",
  "license": "MIT",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "icon": "node build/make-icon.cjs",
    "server": "node server/convert-server.js",
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist:win": "npm run icon && npm run build && electron-builder --win portable --x64",
    "dist:win:installer": "npm run icon && npm run build && electron-builder --win nsis --x64",
    "dist:linux": "npm run icon && npm run build && electron-builder --linux AppImage deb --x64 --publish never"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.pdftools.desktop",
    "productName": "PDF Tools",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "PDF-Tools-${version}.exe"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Office",
      "maintainer": "atemelci <temelcia13@gmail.com>",
      "artifactName": "PDF-Tools.${ext}",
      "executableName": "pdf-tools"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF Tools",
      "artifactName": "PDF-Tools-Setup-${version}.exe"
    }
  }
}
